# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_DSN=host=localhost user=auth password=secret dbname=auth_engine port=5432 sslmode=disable TimeZone=UTC

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ─── JWT (CHANGE THESE!) ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_at_least_32_chars_long_access
JWT_REFRESH_SECRET=change_me_at_least_32_chars_long_refresh
JWT_ISSUER=auth-engine

# ─── Google OAuth ─────────────────────────────────────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_GOOGLE_REDIRECT_URL=https://yourdomain.com/auth/callback/google

# ─── Apple OAuth ──────────────────────────────────────────────────────────────
OAUTH_APPLE_CLIENT_ID=com.yourapp.auth
OAUTH_APPLE_TEAM_ID=TEAMID123
OAUTH_APPLE_KEY_ID=KEYID456
OAUTH_APPLE_PRIVATE_KEY=/path/to/AuthKey.p8

# ─── Email: SendGrid ──────────────────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=MyApp
SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# ─── SMS: Twilio ──────────────────────────────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_ENABLED=false
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json
FIREBASE_PROJECT_ID=your-project

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_ENABLED=false
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
